  },
  "dependencies": {
    "@prisma/client": "7.5.0",
    "dobrunia-liverail-contracts": "1.0.0",
    "dobrunia-liverail-server": "1.0.0",
    "dotenv": "17.3.1",
    "graphql": "16.13.1",
    "graphql-yoga": "5.18.1",
    "mediasoup": "3.19.18",
    "socket.io": "^4.8.3",
    "strictql": "1.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "prisma": "7.5.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
